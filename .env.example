# Anthropic — clave para llamar al modelo Claude
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx

# SAP HANA — fuente de datos de inventario (esquema TRESB)
HANA_HOST=hana.miempresa.com
HANA_PORT=30015
HANA_USER=USUARIO
HANA_PASS=xxxxxxxx

# SendGrid — envío de reportes por email
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email remitente (debe estar verificado en SendGrid)
REPORT_FROM_EMAIL=noreply@tiendas3b.com.bo

# Destinatarios del reporte, separados por coma
REPORT_RECIPIENTS=gerente@tiendas3b.com.bo,analista@tiendas3b.com.bo

# Modelo Claude a usar (opcional)
# Opciones: claude-haiku-4-5-20251001 | claude-sonnet-4-6 | claude-opus-4-8
LLM_MODEL=claude-sonnet-4-6
